//@version=5
indicator("USATECM2026 背离策略", overlay=true, precision=2)

// === 参数 ===
srcTrade = input.symbol("ACTIVTRADES:USATECM2026", title="交易品种")
zEntryLong   = input.float(-1.5, "做多入场 Z-Score", minval=-3.0, maxval=-0.5)
zEntryShort  = input.float(1.5, "做空入场 Z-Score", minval=0.5, maxval=3.0)
zExitLong    = input.float(-0.5, "做多出场 Z-Score")
zExitShort   = input.float(0.5, "做空出场 Z-Score")
lookback     = input.int(100, "计算窗口", minval=20)
profitTarget = input.float(20.0, "目标点数")
minHold      = input.int(30, "最小持有bars")
divLookback  = input.int(10, "背离检测窗口")

// === 获取数据 ===
tradeClose = request.security(srcTrade, timeframe.period, close)
spread = tradeClose  // 使用单一品种价格作为价差

// 计算Z-Score (使用价格的滚动均值和标准差)
mean   = ta.sma(spread, lookback)
std    = ta.stdev(spread, lookback)
zScore = (spread - mean) / std

// === 背离检测 ===
// 看涨背离：价格创新低但Z-Score没有创新低
priceLow  = ta.lowest(spread, divLookback * 2)
zLow      = ta.lowest(zScore, divLookback * 2)
bullDiv   = spread < priceLow[divLookback] and zScore > zLow[divLookback] and zLow[divLookback] < zEntryLong

// 看跌背离：价格创新高但Z-Score没有创新高
priceHigh = ta.highest(spread, divLookback * 2)
zHigh     = ta.highest(zScore, divLookback * 2)
bearDiv   = spread > priceHigh[divLookback] and zScore < zHigh[divLookback] and zHigh[divLookback] > zEntryShort

// === 入场信号 ===
// 做多：Z-Score <= -1.5 或 看涨背离
longSignal  = (zScore <= zEntryLong or bullDiv) and pos == 0

// 做空：Z-Score >= +1.5 或 看跌背离
shortSignal = (zScore >= zEntryShort or bearDiv) and pos == 0

// === 持仓管理 ===
var int pos = 0
var float entryPrice = na
var int entryBar = 0

pos := longSignal ? 1 : shortSignal ? -1 : pos

if longSignal
    entryPrice := spread
    entryBar := bar_index

if shortSignal
    entryPrice := spread
    entryBar := bar_index

// === 出场 ===
barsHeld = bar_index - entryBar
initHoldOk = barsHeld >= minHold
pnl = pos == 1 ? spread - entryPrice : pos == -1 ? entryPrice - spread : 0.0

// 做多出场：Z-Score >= -0.5 或 达到目标
exitLong  = pos == 1 and (zScore >= zExitLong or (initHoldOk and pnl >= profitTarget))

// 做空出场：Z-Score <= +0.5 或 达到目标
exitShort = pos == -1 and (zScore <= zExitShort or (initHoldOk and pnl >= profitTarget))

if exitLong or exitShort
    pos := 0
    entryPrice := na

// === 绘图标记 ===
plotshape(longSignal, "买入", location.bottom, shape.labelup, color.green, size=size.medium, text="BUY")
plotshape(shortSignal, "卖出", location.top, shape.labeldown, color.red, size=size.medium, text="SELL")

plotshape(exitLong, "平多", location.top, shape.labeldown, color.orange, size=size.small, text="EXIT")
plotshape(exitShort, "平空", location.bottom, shape.labelup, color.orange, size=size.small, text="EXIT")

// Z-Score 色块（超买超卖区域）
bgcolor(zScore <= zEntryLong ? color.new(color.blue, 80) : zScore >= zEntryShort ? color.new(color.red, 80) : na)

// === Dashboard ===
var table dash = table.new(position.top_right, 2, 6, color.gray)
if barstate.islast
    table.cell(dash, 0, 0, "Z-Score", bgcolor=color.gray, text_color=color.white)
    table.cell(dash, 1, 0, str.tostring(zScore, "#.##"), 
         bgcolor=zScore < zEntryLong ? color.blue : zScore > zEntryShort ? color.red : color.gray)
    table.cell(dash, 0, 1, "价差", bgcolor=color.gray)
    table.cell(dash, 1, 1, str.tostring(spread, "#.##"))
    table.cell(dash, 0, 2, "持仓", bgcolor=color.gray)
    table.cell(dash, 1, 2, pos == 1 ? "多头" : pos == -1 ? "空头" : "空仓", 
         bgcolor=pos == 1 ? color.green : pos == -1 ? color.red : color.gray)
    table.cell(dash, 0, 3, "浮盈", bgcolor=color.gray)
    table.cell(dash, 1, 3, str.tostring(pnl, "#.##"), bgcolor=pnl > 0 ? color.green : pnl < 0 ? color.red : color.gray)
    table.cell(dash, 0, 4, "持有", bgcolor=color.gray)
    table.cell(dash, 1, 4, str.tostring(barsHeld), bgcolor=initHoldOk ? color.green : color.gray)
    table.cell(dash, 0, 5, "目标", bgcolor=color.gray)
    table.cell(dash, 1, 5, str.tostring(profitTarget, "#.#"), bgcolor=pnl >= profitTarget ? color.green : color.gray)

// === Alerts ===
alertcondition(longSignal, "买入", "Z-Score达到 {{zEntryLong}} 或底背离")
alertcondition(shortSignal, "卖出", "Z-Score达到 {{zEntryShort}} 或顶背离")
alertcondition(exitLong, "平多", "多头出场")
alertcondition(exitShort, "平空", "空头出场")

// === Z-Score 指标线 ===
plot(zScore, "Z", color.blue, linewidth=2)
plot(mean, "均值", color.gray, linewidth=1)
hline(zEntryShort, "上轨", color.maroon, linestyle=hline.style_dashed)
hline(zEntryLong, "下轨", color.green, linestyle=hline.style_dashed)
hline(0, "零线", color.gray, linestyle=hline.style_dotted)
